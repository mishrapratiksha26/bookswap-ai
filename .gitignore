.env
bash.exe.stackdump.env

# Python caches
__pycache__/
*.pyc

# Local uvicorn log artefact from testing
server_test.log

# Experiment run logs — append-only, grow unbounded, not source.
# Commit *frozen* snapshots into experiments/snapshots/ instead.
experiments/*.jsonl
!experiments/snapshots/**

# Cached catalogue PDFs from IIT ISM scraper (re-downloadable from their site).
# The parsed courses.json IS committed so the app has a canonical list offline.
data/iitism_courses/
